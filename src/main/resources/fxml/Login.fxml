<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import java.net.URL?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.velvet_note.controladores.LoginController"
           prefWidth="900" prefHeight="550"
           styleClass="login-root">

    <stylesheets>
        <URL value="@../css/styles.css"/>
    </stylesheets>

    <!-- tarjeta central -->
    <VBox alignment="CENTER"
          spacing="20"
          maxWidth="500"
          maxHeight="420"
          styleClass="login-card">
        <Label text="Bienvenido"
               styleClass="login-title"/>
        <Region prefHeight="6"/>
        <TextField fx:id="txtUsername"
                   promptText="Usuario"
                   prefWidth="420"
                   styleClass="login-input"/>
        <PasswordField fx:id="txtPassword"
                       promptText="Contraseña"
                       prefWidth="420"
                       onAction="#handleLogin"
                       styleClass="login-input"/>
        <Label fx:id="lblError"
               text=""
               styleClass="login-error"/>
        <Region prefHeight="8"/>
        <Button fx:id="btnLogin"
                text="Ingresar"
                prefWidth="420"
                onAction="#handleLogin"
                styleClass="login-button"/>
    </VBox>
</StackPane>